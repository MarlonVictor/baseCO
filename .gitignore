# =============================================================================
# SEO Base — .gitignore para repositório PÚBLICO (portfólio / currículo)
# Objetivo: nunca commitar segredos, caches, builds ou artefatos locais.
# =============================================================================

# -----------------------------------------------------------------------------
# Segredos e credenciais (NUNCA versionar)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example
*.pem
*.key
*.p12
*.pfx
credentials.json
service-account*.json
secrets.json
.secrets/
.netlify/
.vercel/

# -----------------------------------------------------------------------------
# Dependências
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# Build e caches de compilação
# -----------------------------------------------------------------------------
**/dist/
.output/
**/.astro/
.turbo/
.cache/
**/.vite/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Testes e relatórios de qualidade (gerados localmente / CI)
# -----------------------------------------------------------------------------
playwright-report/
test-results/
blob-report/
playwright/.cache/
playwright/.auth/
coverage/
.nyc_output/
.lighthouseci/
reports/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
bun-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Sistema operacional
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Editores e IDE (configuração pessoal — não exportar)
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# IDE local (configuração pessoal — não exportar)
.cursor/

# -----------------------------------------------------------------------------
# Arquivos temporários e backups
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.backup

# -----------------------------------------------------------------------------
# Lockfiles de outros gerenciadores (projeto usa Bun — versionar bun.lock)
# -----------------------------------------------------------------------------
package-lock.json
pnpm-lock.yaml
yarn.lock
