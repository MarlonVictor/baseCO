# =============================================================================
# baseCO — .gitignore para repositório PÚBLICO (portfólio / currículo)
# Objetivo: nunca commitar segredos, caches, builds ou artefatos locais.
# =============================================================================

# -----------------------------------------------------------------------------
# Segredos e credenciais (NUNCA versionar)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example
.envrc
.dev.vars
*.pem
*.key
*.p12
*.pfx
*.ppk
id_rsa
id_ed25519
id_ecdsa
id_dsa
credentials.json
service-account*.json
secrets.json
.secrets/
auth.json
token.json
.htpasswd
.npmrc
!.npmrc.example
.netlify/
.vercel/
.wrangler/

# Overrides locais (CMS, deploy, etc.)
**/config.local.yml
**/config.local.*.yml
local.config.*
*.local.json

# -----------------------------------------------------------------------------
# Dependências
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# Build e caches de compilação
# -----------------------------------------------------------------------------
**/dist/
.output/
**/.astro/
.turbo/
.cache/
**/.vite/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Testes e relatórios de qualidade (gerados localmente / CI)
# -----------------------------------------------------------------------------
playwright-report/
test-results/
blob-report/
playwright/.cache/
playwright/.auth/
.playwright/
coverage/
.nyc_output/
.lighthouseci/
reports/
.lighthouserc.generated.json

# -----------------------------------------------------------------------------
# Uploads de cliente (manter só .gitkeep no template)
# -----------------------------------------------------------------------------
public/assets/uploads/*
!public/assets/uploads/.gitkeep

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
bun-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Sistema operacional
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Editores e IDE (configuração pessoal — não exportar)
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# Cursor (regras, índice, MCP local — não versionar)
.cursor/
.cursor/**
.cursorignore
.cursorrules
.cursorindexingignore

# -----------------------------------------------------------------------------
# Arquivos temporários e backups
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.backup

# -----------------------------------------------------------------------------
# Bancos / estado local
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db-journal

# -----------------------------------------------------------------------------
# Lockfiles de outros gerenciadores (projeto usa Bun — versionar bun.lock)
# -----------------------------------------------------------------------------
package-lock.json
pnpm-lock.yaml
yarn.lock
