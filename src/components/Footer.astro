---
/**
 * Footer.astro
 * ------------
 * Rodapé com landmark `<footer role="contentinfo">`. Contém marca,
 * navegação secundária, redes sociais e copyright.
 */

export interface FooterLink {
  label: string;
  href: string;
}

export interface SocialLink {
  label: string; // visível para leitores de tela
  href: string;
  icon?: string;
}

export interface Props {
  brand?: string;
  tagline?: string;
  navItems?: FooterLink[];
  socials?: SocialLink[];
  legal?: FooterLink[];
}

const currentYear = new Date().getFullYear();

const {
  brand = 'Seu Negócio',
  tagline = 'Soluções locais com excelência desde 2015.',
  navItems = [
    { label: 'Diferenciais', href: '#features' },
    { label: 'Depoimentos', href: '#depoimentos' },
    { label: 'Contato', href: '#contato' },
  ],
  socials = [
    { label: 'Instagram', href: 'https://instagram.com/seunegocio', icon: 'IG' },
    { label: 'Facebook', href: 'https://facebook.com/seunegocio', icon: 'FB' },
    { label: 'WhatsApp', href: 'https://wa.me/5511999999999', icon: 'WA' },
  ],
  legal = [
    { label: 'Política de Privacidade', href: '/privacidade' },
    { label: 'Termos de Uso', href: '/termos' },
  ],
} = Astro.props;
---

<footer
  class="footer mt-auto w-full"
  role="contentinfo"
  data-section="footer"
>
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="footer__grid grid gap-10 md:grid-cols-3">
      <div class="footer__brand-block">
        <p class="footer__brand text-lg font-bold">{brand}</p>
        {tagline && <p class="footer__tagline mt-2 text-sm">{tagline}</p>}
      </div>

      <nav class="footer__nav" aria-label="Navegação do rodapé">
        <p class="footer__heading text-sm font-semibold uppercase tracking-wider">Navegação</p>
        <ul class="mt-3 flex flex-col gap-2">
          {navItems.map((item) => (
            <li>
              <a href={item.href} class="footer__link inline-block">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="footer__socials">
        <p class="footer__heading text-sm font-semibold uppercase tracking-wider">Redes</p>
        <ul class="mt-3 flex gap-3" role="list">
          {socials.map((s) => (
            <li>
              <a
                href={s.href}
                class="footer__social inline-flex h-10 w-10 items-center justify-center rounded"
                aria-label={s.label}
                rel="noopener noreferrer"
                target="_blank"
              >
                <span aria-hidden="true">{s.icon ?? s.label.slice(0, 2).toUpperCase()}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer__bottom mt-10 flex flex-col items-start justify-between gap-4 border-t pt-6 md:flex-row md:items-center">
      <p class="footer__copyright text-sm">
        © {currentYear} {brand}. Todos os direitos reservados.
      </p>
      <ul class="flex flex-wrap gap-x-4 gap-y-2" role="list">
        {legal.map((item) => (
          <li>
            <a href={item.href} class="footer__legal text-sm">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <!-- DESIGN SYSTEM HOOK: estilize .footer, .footer__link, .footer__social -->
</footer>
