---
/**
 * Features.astro
 * --------------
 * Grid responsivo de diferenciais. Mobile-first: 1 coluna no mobile,
 * 2 em tablets, 3 em desktops.
 */

export interface Feature {
  title: string;
  description: string;
  /** Emoji, sigla ou caminho de ícone — substituir pelo componente do DS. */
  icon?: string;
}

export interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  features?: Feature[];
}

const {
  eyebrow = 'Por que nos escolher',
  title = 'Diferenciais que entregam resultado',
  description = 'Combinamos experiência local e processos enxutos para entregar valor desde o primeiro contato.',
  features = [
    { icon: '⚡', title: 'Atendimento ágil', description: 'Resposta em até 1h em horário comercial e suporte recorrente.' },
    { icon: '🛠️', title: 'Equipe especializada', description: 'Profissionais certificados, com casos reais no segmento.' },
    { icon: '📍', title: 'Atuação local', description: 'Presença na sua região com visitas técnicas quando necessário.' },
    { icon: '✅', title: 'Garantia estendida', description: 'Cobertura de 12 meses em todos os serviços contratados.' },
    { icon: '💬', title: 'Comunicação clara', description: 'Acompanhamento por WhatsApp e relatórios semanais.' },
    { icon: '⭐', title: 'Avaliação 4.9/5', description: 'Mais de 500 clientes recomendam nosso trabalho.' },
  ],
} = Astro.props;
---

<section
  id="features"
  class="features w-full"
  aria-labelledby="features-title"
  data-section="features"
>
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 md:py-24">
    <header class="features__header mx-auto max-w-2xl text-center">
      {eyebrow && (
        <p class="features__eyebrow text-sm font-medium uppercase tracking-wider">
          {eyebrow}
        </p>
      )}
      <h2
        id="features-title"
        class="features__title mt-2 text-3xl font-bold sm:text-4xl"
      >
        {title}
      </h2>
      {description && (
        <p class="features__description mt-4 text-base sm:text-lg">
          {description}
        </p>
      )}
    </header>

    <ul
      class="features__grid mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
      role="list"
    >
      {features.map((feature) => (
        <li class="features__item rounded-lg p-6">
          <div class="features__icon mb-4 inline-flex h-12 w-12 items-center justify-center rounded text-2xl" aria-hidden="true">
            {feature.icon}
          </div>
          <h3 class="features__item-title text-lg font-semibold">
            {feature.title}
          </h3>
          <p class="features__item-description mt-2 text-base">
            {feature.description}
          </p>
        </li>
      ))}
    </ul>
  </div>

  <!-- DESIGN SYSTEM HOOK: estilize .features, .features__item, .features__icon -->
  <!-- ANIMAÇÃO: stagger de entrada nos cards via IntersectionObserver -->
</section>
