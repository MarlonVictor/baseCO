---
/**
 * Contact.astro
 * -------------
 * Seção de contato com formulário acessível e bloco de informações
 * complementares (telefone, e-mail, endereço, horário). Mobile-first:
 * empilhado no mobile, 2 colunas no desktop.
 *
 * Acessibilidade:
 *  - <label> associada a cada input via `for`/`id`.
 *  - Campos obrigatórios marcados com `aria-required` e `required`.
 *  - `autocomplete` adequado para preenchimento automático.
 *
 * O `action` está vazio: integre com seu provedor (Formspree, Netlify Forms,
 * endpoint próprio, etc.) ou intercepte via JS no Design System.
 */

export interface ContactInfo {
  phone?: string;
  /** Número exibido; link usa https://wa.me/{apenas dígitos} */
  whatsapp?: string;
  email?: string;
  address?: string;
  hours?: string;
}

export interface Props {
  eyebrow?: string;
  title?: string;
  description?: string;
  info?: ContactInfo;
  formAction?: string;
}

const {
  eyebrow = 'Contato',
  title = 'Vamos conversar?',
  description = 'Preencha o formulário ou utilize um de nossos canais. Respondemos em até 1 dia útil.',
  info = {
    phone: '+55 (11) 99999-9999',
    email: 'contato@exemplo.com.br',
    address: 'Av. Paulista, 1000 — São Paulo/SP',
    hours: 'Segunda a Sexta, 9h às 18h',
  },
  formAction = '',
} = Astro.props;
---

<section
  id="contato"
  class="contact w-full"
  aria-labelledby="contact-title"
  data-section="contact"
>
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 md:py-24">
    <header class="contact__header mx-auto max-w-2xl text-center">
      {eyebrow && (
        <p class="contact__eyebrow text-sm font-medium uppercase tracking-wider">
          {eyebrow}
        </p>
      )}
      <h2
        id="contact-title"
        class="contact__title mt-2 text-3xl font-bold sm:text-4xl"
      >
        {title}
      </h2>
      {description && (
        <p class="contact__description mt-4 text-base sm:text-lg">
          {description}
        </p>
      )}
    </header>

    <div class="contact__grid mt-12 grid gap-10 md:grid-cols-2 md:gap-12">
      <form
        class="contact__form flex flex-col gap-4"
        method="post"
        action={formAction}
        novalidate
      >
        <div class="contact__field">
          <label for="contact-name" class="contact__label block text-sm font-medium">
            Nome
          </label>
          <input
            type="text"
            id="contact-name"
            name="name"
            autocomplete="name"
            required
            aria-required="true"
            class="contact__input mt-1 block w-full rounded border px-3 py-2"
          />
        </div>

        <div class="contact__field">
          <label for="contact-email" class="contact__label block text-sm font-medium">
            E-mail
          </label>
          <input
            type="email"
            id="contact-email"
            name="email"
            autocomplete="email"
            required
            aria-required="true"
            class="contact__input mt-1 block w-full rounded border px-3 py-2"
          />
        </div>

        <div class="contact__field">
          <label for="contact-phone" class="contact__label block text-sm font-medium">
            Telefone <span class="text-xs font-normal">(opcional)</span>
          </label>
          <input
            type="tel"
            id="contact-phone"
            name="phone"
            autocomplete="tel"
            class="contact__input mt-1 block w-full rounded border px-3 py-2"
          />
        </div>

        <div class="contact__field">
          <label for="contact-message" class="contact__label block text-sm font-medium">
            Mensagem
          </label>
          <textarea
            id="contact-message"
            name="message"
            rows="5"
            required
            aria-required="true"
            class="contact__input mt-1 block w-full rounded border px-3 py-2"
          ></textarea>
        </div>

        <button
          type="submit"
          class="contact__submit inline-flex items-center justify-center rounded px-6 py-3 font-medium"
        >
          Enviar mensagem
        </button>
      </form>

      <aside class="contact__info" aria-label="Outras formas de contato">
        <ul class="flex flex-col gap-5">
          {info.whatsapp && (
            <li class="contact__info-item">
              <span class="contact__info-label block text-sm font-medium">WhatsApp</span>
              <a
                href={`https://wa.me/${info.whatsapp.replace(/\D/g, '')}`}
                class="contact__info-value block"
                rel="noopener noreferrer"
                target="_blank"
              >
                {info.whatsapp}
              </a>
            </li>
          )}
          {info.phone && (
            <li class="contact__info-item">
              <span class="contact__info-label block text-sm font-medium">Telefone</span>
              <a href={`tel:${info.phone.replace(/[^+\d]/g, '')}`} class="contact__info-value block">
                {info.phone}
              </a>
            </li>
          )}
          {info.email && (
            <li class="contact__info-item">
              <span class="contact__info-label block text-sm font-medium">E-mail</span>
              <a href={`mailto:${info.email}`} class="contact__info-value block">
                {info.email}
              </a>
            </li>
          )}
          {info.address && (
            <li class="contact__info-item">
              <span class="contact__info-label block text-sm font-medium">Endereço</span>
              <address class="contact__info-value not-italic">{info.address}</address>
            </li>
          )}
          {info.hours && (
            <li class="contact__info-item">
              <span class="contact__info-label block text-sm font-medium">Horário</span>
              <span class="contact__info-value block">{info.hours}</span>
            </li>
          )}
        </ul>
      </aside>
    </div>
  </div>

  <!-- DESIGN SYSTEM HOOK: estilize .contact__input, .contact__submit, .contact__info -->
  <!-- ANIMAÇÃO / VALIDAÇÃO: ponto para script de validação custom + envio AJAX -->
</section>
