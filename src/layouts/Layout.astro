---
/**
 * Layout.astro
 * ------------
 * Layout principal: gerencia <head> (SEO, Open Graph, Twitter, JSON-LD) e
 * estrutura semântica do <body>. Todas as meta-tags são dinâmicas via props,
 * com defaults sensatos para uso rápido em qualquer página.
 */

import "~/styles/global.css";
import "~/styles/a11y.css";
import "~/styles/dialog.css";
import SkipLink from "~/components/primitives/SkipLink.astro";
import LocalBusinessJsonLd from "~/seo/LocalBusinessJsonLd.astro";
import type { LocalBusinessSchema } from "~/seo/types";

export type { LocalBusinessSchema };

export interface Props {
  /** Título exibido na aba do navegador e no <title>. */
  title: string;
  /** Resumo da página (até ~160 caracteres) para SERPs e OG. */
  description: string;
  /** URL canônica. Default: URL atual da requisição. */
  canonical?: string;
  /** Idioma do conteúdo (atributo `lang` do <html>). Default: 'pt-BR'. */
  lang?: string;
  /** Locale do Open Graph (ex: 'pt_BR'). Default derivado de `lang`. */
  ogLocale?: string;
  /** Imagem para Open Graph / Twitter. Caminho absoluto ou relativo. */
  image?: string;
  /** Tipo do Open Graph. */
  type?: "website" | "article" | "product";
  /** Nome do site (og:site_name). */
  siteName?: string;
  /** Bloqueia indexação por crawlers. */
  noindex?: boolean;
  /** Cor da barra do navegador em mobile (theme-color). */
  themeColor?: string;
  /** Dados estruturados Schema.org/LocalBusiness (opcional). */
  localBusiness?: LocalBusinessSchema;
}

const {
  title,
  description,
  canonical,
  lang = "pt-BR",
  ogLocale,
  // NOTA: SVG é apenas placeholder. Para produção use /og-default.jpg (1200x630)
  // — alguns crawlers (LinkedIn, WhatsApp) ignoram OG image em SVG.
  image = "/og-default.jpg",
  type = "website",
  siteName = "Seu Negócio",
  noindex = false,
  themeColor = "#ffffff",
  localBusiness,
} = Astro.props;

const canonicalUrl =
  canonical ?? new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const ogImage = new URL(image, Astro.site ?? Astro.url).toString();
const ogLocaleResolved = ogLocale ?? lang.replace("-", "_");
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content={themeColor} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {
      !noindex && (
        <meta name="robots" content="index, follow, max-image-preview:large" />
      )
    }

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocaleResolved} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {localBusiness && <LocalBusinessJsonLd {...localBusiness} />}

    <!-- ===========================================================================
         === FONTS ===
         Insira aqui <link rel="preconnect"> e <link rel="preload"> de fontes
         do Design System externo. Use `font-display: swap` no @font-face
         (definido em CSS importado por global.css ou pelo próprio DS).
         Exemplo:
           <link rel="preconnect" href="https://fonts.googleapis.com" />
           <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
           <link
             rel="preload"
             href="/fonts/brand-regular.woff2"
             as="font"
             type="font/woff2"
             crossorigin
           />
         =========================================================================== -->

    <!-- ===========================================================================
         === DESIGN SYSTEM CSS (override) ===
         Inclua aqui <link rel="stylesheet"> do Design System externo OU
         importe-o em src/styles/global.css. Mantenha-o APÓS as utilities do
         Tailwind para garantir precedência (já é o caso quando importado pelo
         global.css, no bloco "DESIGN SYSTEM OVERRIDES").
         =========================================================================== -->
  </head>

  <body class="min-h-screen flex flex-col antialiased">
    <SkipLink />

    <slot />

    <!-- ===========================================================================
         === SCRIPTS GLOBAIS ===
         Ponto de injeção para scripts globais do Design System / animações
         (ex: GSAP, Lenis, IntersectionObserver, analytics).
         Prefira `is:inline` apenas para snippets críticos; demais scripts devem
         vir como módulos `<script src="..." defer>` para não bloquear o LCP.
         =========================================================================== -->
  </body>
</html>
