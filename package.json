{
  "name": "seo-base",
  "type": "module",
  "version": "0.2.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "description": "Boilerplate monorepo de landing pages estáticas — Astro, Tailwind, SEO local e alta performance.",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/config/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "preview": "turbo preview",
    "lint": "eslint apps/ packages/",
    "test:e2e": "turbo test:e2e",
    "format": "prettier --write \"**/*.{astro,ts,js,mjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{astro,ts,js,mjs,json,md,css}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "turbo": "^2.3.3",
    "typescript-eslint": "^8.18.2"
  }
}
